---
import { Instagram, Facebook } from "lucide-astro";
import Heading from "./Heading.astro";
import Text from "./Text.astro";
import Button from "./Button.astro";
---

<footer class="mt-20">
  <!-- Newsletter -->
  <section class="bg-white intersect:animate-flip-up animate-once">
    <form id="newsletterForm" class="w-full flex flex-col md:flex-row items-stretch">
      <!-- INPUT -->
      <div class="flex-1 flex items-stretch px-margin-mobile lg:px-margin-desktop py-6 md:py-0">
        <div class="w-full relative flex items-center">
          <input id="emailInput" type="email" required placeholder="" class="w-full bg-transparent border-0 outline-none text-sm md:text-base text-black py-4 pl-0 peer focus:outline-none focus:ring-0" />
          <!-- LABEL -->
          <label
            class="absolute left-0 top-1/2 -translate-y-1/2 text-grey-400 pointer-events-none transition-all duration-200 text-xl md:text-2xl font-semibold tracking-wide peer-focus:-top-2 peer-focus:text-grey-300 peer-valid:-top-2 peer-valid:text-grey-300"
          >
            BOOM BUTIKS NYHEDSBREV
          </label>
        </div>
      </div>
      <!-- BUTTON -->
      <button
        type="submit"
        class="flex items-center justify-center bg-button-secondary-default hover:bg-button-secondary-hover active:bg-button-secondary-active text-text-button-primary hover:text-text-button-secondary px-6 py-3 md:px-16 md:py-5 text-sm md:text-base font-medium tracking-wide hover:opacity-80 transition-opacity w-full md:w-96 cursor-pointer"
      >
        TILMELD NU
      </button>
    </form>
    <!-- POPUP -->
    <div id="toast" class="fixed bottom-6 left-1/2 -translate-x-1/2 bg-black text-white px-6 py-3 text-sm rounded-full opacity-0 translate-y-4 pointer-events-none transition-all duration-300">Tak for din tilmelding ✨</div>
  </section>

  <!-- Footer content -->
  <section class="bg-grey-100 w-full py-16 md:py-20 px-margin-mobile lg:px-margin-desktop">
    <!-- Media logos -->
    <div class="mb-16">
      <Heading htmlheading="h5" size="xsmall" weight="semibold" color="primary"> OMTALT I FLOTTE MEDIER </Heading>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mt-8">
        <!-- 1 -->
        <img src="footer1.svg" alt="Politiken" class="h-7 md:h-9 w-auto object-contain justify-self-start" />

        <!-- 2 -->
        <img src="footer2.svg" alt="Forbes" class="h-7 md:h-9 w-auto object-contain justify-self-start md:justify-self-center" />

        <!-- 3 -->
        <img src="footer3.svg" alt="Euroman" class="h-7 md:h-9 w-auto object-contain justify-self-start md:justify-self-center" />

        <!-- 4 -->
        <img src="footer4.svg" alt="Berlingske" class="h-7 md:h-9 w-auto object-contain justify-self-start md:justify-self-end" />
      </div>
    </div>

    <!-- Footer columns -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-10 lg:gap-16">
      <div class="flex flex-col items-center sm:items-start text-center sm:text-left order-last lg:order-none">
        <img src="Vector.svg" alt="logo" class="mb-6 h-20" />

        <Text class="text-center sm:text-left"> © 2025 BOOM BUTIK ApS, CVR: 44150875 </Text>
      </div>

      <div>
        <Heading htmlheading="h5" size="xsmall" weight="semibold" color="primary"> KONTAKT </Heading>
        <div class="mt-2 md:mt-4">
          <Text>E-mail:</Text>
          <a href="mailto:kontakt@boombutik.dk" class="hover:underline"> kontakt@boombutik.dk </a>
        </div>
      </div>

      <div>
        <Heading htmlheading="h5" size="xsmall" weight="semibold" color="primary"> KØBSBETINGELSER </Heading>

        <ul class="space-y-2 mt-2 md:mt-4">
          <li><a href="#" class="hover:underline">Levering</a></li>
          <li><a href="#" class="hover:underline">Returnering</a></li>
          <li><a href="#" class="hover:underline">Privatliv</a></li>
          <li><a href="#" class="hover:underline">Handelsbetingelser</a></li>
          <li><a href="#" class="hover:underline">Studierabat</a></li>
        </ul>
      </div>

      <div>
        <Heading htmlheading="h5" size="xsmall" weight="semibold" color="primary"> FYSISK BUTIK </Heading>

        <div class="space-y-4 mt-2 md:mt-4">
          <Text>
            Blågårdsgade 14,<br />
            2200 København
          </Text>

          <Text>
            Åbent alle ugens dage:<br />
            12.00 - 18.00
          </Text>
        </div>
      </div>

      <div>
        <Heading htmlheading="h5" size="xsmall" weight="semibold" color="primary"> FØLG OS </Heading>

        <div class="flex items-center gap-5 mt-2 md:mt-4">
          <a href="https://www.instagram.com/boombutik/" target="_blank" rel="noopener noreferrer" class="transition-transform duration-200 hover:scale-110">
            <Instagram size={50} strokeWidth={2.2} />
          </a>

          <a href="https://www.facebook.com/profile.php?id=100063946218136" target="_blank" rel="noopener noreferrer" class="transition-transform duration-200 hover:scale-110">
            <Facebook size={50} strokeWidth={2.2} />
          </a>
        </div>
      </div>
    </div>
  </section>
</footer>

<script>
  const form = document.getElementById("newsletterForm");
  const input = document.getElementById("emailInput");
  const toast = document.getElementById("toast");

  input.addEventListener("focus", () => {
    input.setAttribute("placeholder", "kontakt@boombutik.dk");
  });

  input.addEventListener("blur", () => {
    if (!input.value) {
      input.removeAttribute("placeholder");
    }
  });

  form.addEventListener("submit", (e) => {
    e.preventDefault();

    if (!input.value) return;

    toast.classList.remove("opacity-0", "translate-y-4");
    toast.classList.add("opacity-100", "translate-y-0");

    input.value = "";
    input.removeAttribute("placeholder");

    setTimeout(() => {
      toast.classList.add("opacity-0", "translate-y-4");
      toast.classList.remove("opacity-100", "translate-y-0");
    }, 3000);
  });
</script>
