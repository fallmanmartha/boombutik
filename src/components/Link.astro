---
// Henter parametrene fra Astro.props
const { href = "#", target = "_self", variant = "textlink", size = "default", text = "primary" } = Astro.props;

const linkStyling = {
  primary: "uppercase font-semibold hover:underline",
  secondary: "",
};

//Definer den styling (Tailwind classes), der gør sig gældende for de forskellige varianter
const variantClasses = {
  primary: "inline-block border-2 px-16 py-4 border-black" /* border-primary-500 */,
  secondary: "inline-block border-2 px-16 py-4 border-blue-500" /* border-secondary-500 */,
};

//Definer den styling (Tailwind classes), der gør sig gældende for de forskelligeog størrelser.
const sizeClasses = {
  default: "text-mobile-p lg:text-desktop-p",
};
---

<!--Sæt classes for den pågældende knap sammen ved hjælp af Astros class:list -->
<a href={href} target={target} class:list={[linkStyling[text], variantClasses[variant], sizeClasses[size]]}><slot /></a>
