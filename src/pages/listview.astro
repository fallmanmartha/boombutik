---
import MainLayout from "../layouts/MainLayout.astro";
import ProductCard from "../components/ProductCard.astro";
import { fetchProducts } from "../lib/supabase";

// Hent alle produkter fra Supabase
const products = await fetchProducts();

// Definer grid-styling
const gridClasses = "grid grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-grid-gap-desktop";
---

<MainLayout title="Produkter">
  <main class="container mx-auto p-2">
    {products.length === 0 && <p class="font-sans text-gray-500">Ingen produkter fundet.</p>}

    <div class={gridClasses}>
      {products.map((product) => <ProductCard product={product} />)}
    </div>
  </main>
</MainLayout>
