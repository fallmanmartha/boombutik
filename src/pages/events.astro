---
import MainLayout from "../layouts/MainLayout.astro";
import Link from "../components/Link.astro";
import { Image } from "astro:assets";
import thumbsup from "../assets/images/thumbsup.png";
import Heading from "../components/Heading.astro";
import Text from "../components/Text.astro";
import Button from "../components/Button.astro";
---

<MainLayout title="Titel">
  <main class="w-full pt-10 overflow-x-hidden">
    <!-- 4 kolonner og 3 rækker -->
    <!-- ================= DESKTOP LAYOUT ================= -->
    <section class="lg:w-full space-y-1">
      <!-- ========== RÆKKE 1 ========== -->
      <div class="flex gap-2 overflow-x-auto lg:overflow-x-visible snap-x snap-mandatory lg:snap-none pb-2 scrollbar-hide">
        <!-- CARD -->
        <div class="group relative shrink-0 w-3/4 sm:w-1/2 md:w-1/3 lg:w-1/4 snap-start bg-blue-900 text-white overflow-hidden cursor-pointer">
          <div class="absolute inset-0 flex flex-col justify-end p-4 sm:p-5 lg:p-6 transition-opacity duration-300 group-hover:opacity-0">
            <Heading htmlheading="h2" size="large" weight="black" color="secondary"> DISTORTION </Heading>
            <Text color="secondary" class="mt-1"> 6. juni 2026 </Text>
          </div>
          <div class="absolute inset-0 flex flex-col justify-end gap-4 sm:gap-5 lg:gap-6 p-4 sm:p-5 lg:p-6 opacity-0 transition-opacity duration-300 group-hover:opacity-100">
            <Text color="secondary"> Kom forbi DISTORTION x BOOM pop-up event, hvor en hemmelig artist fyrer et par tracks af direkte på gaden. </Text>
            <button onclick="addToCalendar('DISTORTION X BOOM BUTIK', '2026-06-04')" class="flex items-center gap-2 sm:gap-3 w-fit group/cal cursor-pointer">
              <img src="ic_outline-plus.svg" class="w-4 sm:w-5 transition-transform duration-200 group-hover/cal:scale-125" />
              <span class="transition-transform duration-200 group-hover/cal:translate-x-1"> Tilføj til kalender </span>
            </button>
          </div>
        </div>

        <!-- IMAGES -->
        <div class="shrink-0 w-3/4 sm:w-1/2 md:w-1/3 lg:w-1/4 snap-start"><img src="picture.png" class="w-full h-full object-cover" /></div>
        <div class="shrink-0 w-3/4 sm:w-1/2 md:w-1/3 lg:w-1/4 snap-start"><img src="picture-1.png" class="w-full h-full object-cover" /></div>
        <div class="shrink-0 w-3/4 sm:w-1/2 md:w-1/3 lg:w-1/4 snap-start"><img src="picture-2.png" class="w-full h-full object-cover" /></div>
      </div>

      <!-- ========== RÆKKE 2 ========== -->
      <div class="flex gap-2 overflow-x-auto lg:overflow-x-visible snap-x snap-mandatory lg:snap-none pb-2 scrollbar-hide">
        <div class="group relative shrink-0 w-3/4 sm:w-1/2 md:w-1/3 lg:w-1/4 lg:order-4 snap-start bg-red-600 text-white overflow-hidden cursor-pointer">
          <div class="absolute inset-0 flex flex-col justify-end p-4 sm:p-5 lg:p-6 transition-opacity duration-300 group-hover:opacity-0">
            <Heading htmlheading="h2" size="large" weight="black" color="secondary"> BOOMEUR </Heading>
            <Text color="secondary"> 20. juni 2026 </Text>
          </div>
          <div class="absolute inset-0 flex flex-col justify-end gap-4 sm:gap-5 lg:gap-6 p-4 sm:p-5 lg:p-6 opacity-0 transition-opacity duration-300 group-hover:opacity-100">
            <Text color="secondary"> DJ-set, kolde øl og merch drop. </Text>
            <button onclick="addToCalendar('BOOMEUR X BOOM BUTIK', '2026-06-20')" class="flex items-center gap-2 sm:gap-3 w-fit group/cal cursor-pointer">
              <img src="ic_outline-plus.svg" class="w-4 sm:w-5 transition-transform duration-200 group-hover/cal:scale-125" />
              <span class="transition-transform duration-200 group-hover/cal:translate-x-1"> Tilføj til kalender </span>
            </button>
          </div>
        </div>

        <div class="shrink-0 w-3/4 sm:w-1/2 md:w-1/3 lg:w-1/4 snap-start"><img src="picture-3.png" class="w-full h-full object-cover" /></div>
        <div class="shrink-0 w-3/4 sm:w-1/2 md:w-1/3 lg:w-1/4 snap-start"><img src="picture-5.png" class="w-full h-full object-cover" /></div>
        <div class="shrink-0 w-3/4 sm:w-1/2 md:w-1/3 lg:w-1/4 snap-start"><img src="picture-4.png" class="w-full h-full object-cover" /></div>
      </div>

      <!-- ========== RÆKKE 3 ========== -->
      <div class="flex gap-2 overflow-x-auto lg:overflow-x-visible snap-x snap-mandatory lg:snap-none pb-2 scrollbar-hide">
        <div class="group relative shrink-0 w-3/4 sm:w-1/2 md:w-1/3 lg:w-1/4 snap-start bg-orange-500 text-white overflow-hidden cursor-pointer">
          <div class="absolute inset-0 flex flex-col justify-end p-4 sm:p-5 lg:p-6 transition-opacity duration-300 group-hover:opacity-0">
            <Heading htmlheading="h2" size="large" weight="black" color="secondary"> ROSKILDE<br />FESTIVAL </Heading>
            <Text color="secondary"> 1. juli 2026 </Text>
          </div>
          <div class="absolute inset-0 flex flex-col justify-end gap-4 sm:gap-5 lg:gap-6 p-4 sm:p-5 lg:p-6 opacity-0 transition-opacity duration-300 group-hover:opacity-100">
            <Text color="secondary"> Pop-up event med DJ og merch drop. </Text>
            <button onclick="addToCalendar('ROSKILDE FESTIVAL X BOOM BUTIK', '2026-07-01')" class="flex items-center gap-2 sm:gap-3 w-fit group/cal cursor-pointer">
              <img src="ic_outline-plus.svg" class="w-4 sm:w-5 transition-transform duration-200 group-hover/cal:scale-125" />
              <span class="transition-transform duration-200 group-hover/cal:translate-x-1"> Tilføj til kalender </span>
            </button>
          </div>
        </div>

        <div class="shrink-0 w-3/4 sm:w-1/2 md:w-1/3 lg:w-1/4 snap-start"><img src="picture-6.png" class="w-full h-full object-cover" /></div>
        <div class="shrink-0 w-3/4 sm:w-1/2 md:w-1/3 lg:w-1/4 snap-start"><img src="picture-7.png" class="w-full h-full object-cover" /></div>
        <div class="shrink-0 w-3/4 sm:w-1/2 md:w-1/3 lg:w-1/4 snap-start"><img src="picture-8.png" class="w-full h-full object-cover" /></div>
      </div>
    </section>
  </main>
</MainLayout>
<script>
  window.addToCalendar = function (title, date) {
    const formattedDate = date.replaceAll("-", "");

    const url = "https://www.google.com/calendar/render?action=TEMPLATE" + `&text=${encodeURIComponent(title)}` + `&dates=${formattedDate}/${formattedDate}`;

    window.open(url, "_blank");
  };
</script>
