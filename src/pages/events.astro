---
import MainLayout from "../layouts/MainLayout.astro";
import Heading from "../components/Heading.astro";
import Text from "../components/Text.astro";
---

<MainLayout title="Events">
  <!--
    MAIN: Scroll-container
    - h-[calc(100vh-64px)]: fyller skärmen minus navbarens höjd (64px)
    - overflow-y-scroll: vertikal scroll
    - snap-y snap-mandatory: snapper till nästa sektion vid scroll
  -->
  <main class="w-full h-[calc(100vh-64px)] overflow-y-scroll snap-y snap-mandatory px-margin-mobile lg:px-margin-desktop">
    <!-- ==========================================
         SEKTION 1: DISTORTION
         snap-start: sektionen snapper till toppen
         bg-white: vit bakgrund så sektionen täcker föregående
         flex items-center: centrerar korten vertikalt
         overflow-x-auto / lg:overflow-x-hidden: horisontell scroll på mobil, dold på desktop
    =========================================== -->
    <section class="snap-start h-[calc(100vh-64px)] bg-white flex items-center gap-2 overflow-x-auto lg:overflow-x-hidden snap-x snap-mandatory lg:snap-none scrollbar-hide">
      <!-- TEXTCARD: Eventinfo med hover-effekt -->
      <div class="group relative shrink-0 w-3/4 sm:w-1/2 md:w-1/3 lg:flex-1 snap-start bg-blue-900 text-white overflow-hidden cursor-pointer" style="height: 70vh;">
        <!-- DEFAULT-VISNING: Titel og dato (forsvinder ved hover) -->
        <div class="absolute inset-0 flex flex-col justify-end p-4 sm:p-5 lg:p-6 transition-opacity duration-300 group-hover:opacity-0">
          <Heading htmlheading="h2" size="large" weight="black" color="secondary">DISTORTION</Heading>
          <Text color="secondary" class="mt-1">6. juni 2026</Text>
        </div>

        <!-- HOVER-VISNING: Beskrivelse og kalender-knap -->
        <div class="absolute inset-0 flex flex-col justify-end gap-4 sm:gap-5 lg:gap-6 p-4 sm:p-5 lg:p-6 opacity-0 transition-opacity duration-300 group-hover:opacity-100">
          <Text color="secondary">Kom forbi DISTORTION x BOOM pop-up event, hvor en hemmelig artist fyrer et par tracks af direkte på gaden.</Text>
          <button onclick="addToCalendar('DISTORTION X BOOM BUTIK', '2026-06-04')" class="flex items-center gap-2 sm:gap-3 w-fit group/cal cursor-pointer">
            <img src="ic_outline-plus.svg" class="w-4 sm:w-5 transition-transform duration-200 group-hover/cal:scale-125" />
            <span class="transition-transform duration-200 group-hover/cal:translate-x-1">Tilføj til kalender</span>
          </button>
        </div>
      </div>

      <!-- BILLEDKORT 1 -->
      <div class="shrink-0 w-3/4 sm:w-1/2 md:w-1/3 lg:flex-1 snap-start" style="height: 70vh;">
        <img src="picture.png" class="w-full h-full object-cover" />
      </div>

      <!-- BILLEDKORT 2 -->
      <div class="shrink-0 w-3/4 sm:w-1/2 md:w-1/3 lg:flex-1 snap-start" style="height: 70vh;">
        <img src="picture-1.png" class="w-full h-full object-cover" />
      </div>

      <!-- BILLEDKORT 3 -->
      <div class="shrink-0 w-3/4 sm:w-1/2 md:w-1/3 lg:flex-1 snap-start" style="height: 70vh;">
        <img src="picture-2.png" class="w-full h-full object-cover" />
      </div>
    </section>

    <!-- ==========================================
         SEKTION 2: BOOMEUR
         lg:order-4: textcardet placeres sidst på desktop
    =========================================== -->
    <section class="snap-start h-[calc(100vh-64px)] bg-white flex items-center gap-2 overflow-x-auto lg:overflow-x-hidden snap-x snap-mandatory lg:snap-none scrollbar-hide">
      <!-- TEXTCARD: Eventinfo med hover-effekt -->
      <div class="group relative shrink-0 w-3/4 sm:w-1/2 md:w-1/3 lg:flex-1 lg:order-4 snap-start bg-red-600 text-white overflow-hidden cursor-pointer" style="height: 70vh;">
        <!-- DEFAULT-VISNING -->
        <div class="absolute inset-0 flex flex-col justify-end p-4 sm:p-5 lg:p-6 transition-opacity duration-300 group-hover:opacity-0">
          <Heading htmlheading="h2" size="large" weight="black" color="secondary">BOOMEUR</Heading>
          <Text color="secondary">20. juni 2026</Text>
        </div>

        <!-- HOVER-VISNING -->
        <div class="absolute inset-0 flex flex-col justify-end gap-4 sm:gap-5 lg:gap-6 p-4 sm:p-5 lg:p-6 opacity-0 transition-opacity duration-300 group-hover:opacity-100">
          <Text color="secondary">DJ-set, kolde øl og merch drop.</Text>
          <button onclick="addToCalendar('BOOMEUR X BOOM BUTIK', '2026-06-20')" class="flex items-center gap-2 sm:gap-3 w-fit group/cal cursor-pointer">
            <img src="ic_outline-plus.svg" class="w-4 sm:w-5 transition-transform duration-200 group-hover/cal:scale-125" />
            <span class="transition-transform duration-200 group-hover/cal:translate-x-1">Tilføj til kalender</span>
          </button>
        </div>
      </div>

      <!-- BILLEDKORT 1 -->
      <div class="shrink-0 w-3/4 sm:w-1/2 md:w-1/3 lg:flex-1 snap-start" style="height: 70vh;">
        <img src="picture-3.png" class="w-full h-full object-cover" />
      </div>

      <!-- BILLEDKORT 2 -->
      <div class="shrink-0 w-3/4 sm:w-1/2 md:w-1/3 lg:flex-1 snap-start" style="height: 70vh;">
        <img src="picture-5.png" class="w-full h-full object-cover" />
      </div>

      <!-- BILLEDKORT 3 -->
      <div class="shrink-0 w-3/4 sm:w-1/2 md:w-1/3 lg:flex-1 snap-start" style="height: 70vh;">
        <img src="picture-4.png" class="w-full h-full object-cover" />
      </div>
    </section>

    <!-- ==========================================
         SEKTION 3: ROSKILDE FESTIVAL
    =========================================== -->
    <section class="snap-start h-[calc(100vh-64px)] bg-white flex items-center gap-2 overflow-x-auto lg:overflow-x-hidden snap-x snap-mandatory lg:snap-none scrollbar-hide">
      <!-- TEXTCARD: Eventinfo med hover-effekt -->
      <div class="group relative shrink-0 w-3/4 sm:w-1/2 md:w-1/3 lg:flex-1 snap-start bg-orange-500 text-white overflow-hidden cursor-pointer" style="height: 70vh;">
        <!-- DEFAULT-VISNING -->
        <div class="absolute inset-0 flex flex-col justify-end p-4 sm:p-5 lg:p-6 transition-opacity duration-300 group-hover:opacity-0">
          <Heading htmlheading="h2" size="large" weight="black" color="secondary">ROSKILDE<br />FESTIVAL</Heading>
          <Text color="secondary">1. juli 2026</Text>
        </div>

        <!-- HOVER-VISNING -->
        <div class="absolute inset-0 flex flex-col justify-end gap-4 sm:gap-5 lg:gap-6 p-4 sm:p-5 lg:p-6 opacity-0 transition-opacity duration-300 group-hover:opacity-100">
          <Text color="secondary">Pop-up event med DJ og merch drop.</Text>
          <button onclick="addToCalendar('ROSKILDE FESTIVAL X BOOM BUTIK', '2026-07-01')" class="flex items-center gap-2 sm:gap-3 w-fit group/cal cursor-pointer">
            <img src="ic_outline-plus.svg" class="w-4 sm:w-5 transition-transform duration-200 group-hover/cal:scale-125" />
            <span class="transition-transform duration-200 group-hover/cal:translate-x-1">Tilføj til kalender</span>
          </button>
        </div>
      </div>

      <!-- BILLEDKORT 1 -->
      <div class="shrink-0 w-3/4 sm:w-1/2 md:w-1/3 lg:flex-1 snap-start" style="height: 70vh;">
        <img src="picture-6.png" class="w-full h-full object-cover" />
      </div>

      <!-- BILLEDKORT 2 -->
      <div class="shrink-0 w-3/4 sm:w-1/2 md:w-1/3 lg:flex-1 snap-start" style="height: 70vh;">
        <img src="picture-7.png" class="w-full h-full object-cover" />
      </div>

      <!-- BILLEDKORT 3 -->
      <div class="shrink-0 w-3/4 sm:w-1/2 md:w-1/3 lg:flex-1 snap-start" style="height: 70vh;">
        <img src="picture-8.png" class="w-full h-full object-cover" />
      </div>
    </section>
  </main>
</MainLayout>

<script>
  // Funktion til at tilføje events til Google Kalender
  window.addToCalendar = function (title, date) {
    const formattedDate = date.replaceAll("-", "");
    const url = "https://www.google.com/calendar/render?action=TEMPLATE" + `&text=${encodeURIComponent(title)}` + `&dates=${formattedDate}/${formattedDate}`;
    window.open(url, "_blank");
  };

  // Hent main-container og alle sektioner
  const main = document.querySelector("main");
  const sections = document.querySelectorAll("main section");

  // Scroll-animation: skaler og fader sektioner ned når de scrolles væk
  main.addEventListener("scroll", () => {
    sections.forEach((section) => {
      const rect = section.getBoundingClientRect();
      const viewHeight = window.innerHeight;

      // Beregn hvor meget sektionen er scrollet væk (0 = i fokus, 1 = helt væk)
      const scrolledAway = Math.max(0, Math.min(1, -rect.top / viewHeight));

      // Skaler ned fra 1 til 0.65 jo mere den scrolles væk
      const scale = 1 - scrolledAway * 0.35;

      // Fade ud jo mere den scrolles væk
      const opacity = 1 - scrolledAway * 1.5;

      section.style.transform = `scale(${scale})`;
      section.style.transformOrigin = "top center";
      section.style.opacity = String(Math.max(0, opacity));
    });
  });
</script>
